# ─────────────────────────────────────────────────────────────────────
# Cureocity Doctors — environment configuration
# ─────────────────────────────────────────────────────────────────────
# Copy this to `.env` and fill in your keys. The app gracefully runs
# in local-only mode if these are missing — useful for offline dev.
# All client-exposed keys must be prefixed with VITE_ (Vite convention).
# ─────────────────────────────────────────────────────────────────────

# Supabase — auth + persistence + audit log sync
# Create project at https://supabase.com (region: ap-south-1 / Mumbai)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PostHog — product analytics (free tier OK)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry — error tracking (optional)
VITE_SENTRY_DSN=

# Build metadata (optional — Vercel sets these automatically)
VITE_GIT_SHA=

# ─────────────────────────────────────────────────────────────────────
# Sprint 2 — Gemini intake extraction
# ─────────────────────────────────────────────────────────────────────
# GEMINI_API_KEY is server-side only. NEVER prefix with VITE_ — that would
# expose the key to the browser bundle. Used by api/intake/extract.js to
# call Gemini 2.5 Flash for structured clinical extraction.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Feature flag — when true, intake routes through Gemini. When false (or
# absent), falls back to the regex/keyword pipeline. Safe to flip live.
VITE_USE_GEMINI=false

# ─────────────────────────────────────────────────────────────────────
# Slice 6 — Claude Opus clinical reasoning (AI Reasoning tab)
# ─────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY is server-side only. NEVER prefix with VITE_. Used by
# api/ai/reason.js to stream Claude Opus 4.7 reasoning over the engine's
# differential. The endpoint returns 503 if this is missing — the UI
# surfaces the error inline.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# AI-First Pivot (Sprint 0+) — see docs/architecture/ai-first-pivot.md
# ─────────────────────────────────────────────────────────────────────
# Server-side Supabase admin client used by:
#   - api/agent/turn.js      (tool dispatcher writes to tool_calls,
#                             agent_kb_citations, consultation_events)
#   - scripts/ingest_kb.js   (KB ingestion to kb_chunks)
#   - api/realtime/session.js (transcript persistence)
# NEVER prefix with VITE_. Service role bypasses RLS — server-only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Voyage AI — embedding model for KB RAG (1024-dim, voyage-3).
# Server-side only. Used by api/agent/turn.js (query embed) and
# scripts/ingest_kb.js (corpus embed). Get key at https://voyageai.com.
VOYAGE_API_KEY=

# Realtime WebSocket bridge URL (Sprint 1). The spike runs on a
# separate host (Cloudflare Workers / Fly.io / Render) because Vercel
# Node runtime does not support long-lived WS upgrades. SPA points
# here for live transcription.
# Example: wss://realtime.cureocity.in/v1/session
VITE_REALTIME_URL=

# Feature flag — Sprint 4+ rollout. When true, ConsultSurface uses the
# AI-first agent + live transcription. When false (or absent), the
# legacy 7-step engine workflow is shown.
VITE_USE_AGENT=false

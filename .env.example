# ─────────────────────────────────────────────────────────────────────
# Cureocity Doctors — environment configuration
# ─────────────────────────────────────────────────────────────────────
# Copy this to `.env` and fill in your keys. The app gracefully runs
# in local-only mode if these are missing — useful for offline dev.
# All client-exposed keys must be prefixed with VITE_ (Vite convention).
# ─────────────────────────────────────────────────────────────────────

# Supabase — auth + persistence + audit log sync
# Create project at https://supabase.com (region: ap-south-1 / Mumbai)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PostHog — product analytics (free tier OK)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry — error tracking (optional)
VITE_SENTRY_DSN=

# Build metadata (optional — Vercel sets these automatically)
VITE_GIT_SHA=
